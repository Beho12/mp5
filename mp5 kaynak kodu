def get_resource_path(relative_path):
    """ EXE yapıldığında iç kaynaklara, normalde dosya sistemine erişir. """
    try:
        base_path = sys._MEIPASS
    except Exception:
        base_path = os.path.abspath(".")
    return os.path.join(base_path, relative_path)

def generate_mp5_assets():
    """Uygulamanın görsel kimliğini (PNG ve ICO) otonom olarak oluşturur."""
    png_path = os.path.abspath("mp5.png")
    ico_path = os.path.abspath("mp5.ico")
    
    try:
        img = Image.new('RGBA', (512, 512), color=(10, 10, 10, 255))
        draw = ImageDraw.Draw(img)
        draw.ellipse([50, 50, 462, 462], outline=(0, 173, 181), width=25)
        draw.rectangle([200, 150, 240, 362], fill=(0, 173, 181))
        draw.polygon([(240, 150), (312, 250), (384, 150)], fill=(0, 173, 181))
        
        img.save(png_path)
        sizes = [(16, 16), (32, 32), (48, 48), (64, 64), (128, 128), (256, 256)]
        img.save(ico_path, format='ICO', sizes=sizes)
        return ico_path
    except Exception as e:
        print(f"Varlık hatası: {e}")
        return None

def setup_registry_defaults(ico_path):
    """Windows'a .mp5 formatını ve ikonunu mühürler."""
    try:
        app_name = "MP5.Studio.Pro"
        if getattr(sys, 'frozen', False):
            exe_path = f'"{sys.executable}"'
        else:
            exe_path = f'"{sys.executable}" "{os.path.abspath(__file__)}"'

        with reg.CreateKey(reg.HKEY_CURRENT_USER, r"Software\Classes\.mp5") as key:
            reg.SetValue(key, "", reg.REG_SZ, app_name)

        with reg.CreateKey(reg.HKEY_CURRENT_USER, f"Software\\Classes\\{app_name}") as key:
            reg.SetValue(key, "", reg.REG_SZ, "MP5 Video Dosyası")
            with reg.CreateKey(key, "DefaultIcon") as i_key:
                reg.SetValue(i_key, "", reg.REG_SZ, f'"{ico_path}"')
            with reg.CreateKey(key, r"shell\open\command") as c_key:
                reg.SetValue(c_key, "", reg.REG_SZ, f'{exe_path} "%1"')
        
        subprocess.run(["ie4uinit.exe", "-show"], capture_output=True)
        return True
    except:
        return False

def check_libs():
    libs = {"cv2": "opencv-python", "PIL": "pillow", "moviepy": "moviepy", "vlc": "python-vlc"}
    missing = []
    for mod, pkg in libs.items():
        try: __import__(mod)
        except ImportError: missing.append(pkg)
    
    if missing and not getattr(sys, 'frozen', False):
        subprocess.check_call([sys.executable, "-m", "pip", "install"] + missing)
        os.execv(sys.executable, ['python'] + sys.argv)
    return True

